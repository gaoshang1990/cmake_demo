{
    "version": "2.0.0",
    "manual": "https://code.visualstudio.com/docs/editor/tasks",
    "tasks": [
        {
            "label": "make_version",
            "type": "shell",
            "command": "${workspaceFolder}/script/make_version.bat",
            "args": [
                "${workspaceFolder}/src/app"
            ],
            "group": "build"
        },
        {
            "label": "cmake_win32",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset win32"
            ],
            "group": "build",
        },
        {
            "label": "build_win32d",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset win32-debug"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_win32",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset win32-release"
            ],
            "group": "build",
            "dependsOn": [
                "make_version"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "cmake_mingw",
            "type": "shell",
            "command": [
                "cmake"
            ],
            "args": [
                "--preset mingw"
            ],
            "group": "build",
        },
        {
            "label": "build_mingw",
            "type": "process",
            "options": {
                "cwd": "${workspaceFolder}/build/mingw"
            },
            "command": "mingw32-make",
            "group": "build",
            "dependsOn": [],
        },
        {
            "label": "mkdir",
            "type": "shell",
            "command": "mkdir",
            "args": [
                "-p",
                "${workspaceFolder}/build,${workspaceFolder}/build/linux,${workspaceFolder}/build/win32,${workspaceFolder}/build/mingw"
            ],
            "group": "build"
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "${workspaceFolder}/script/clean.bat",
            "group": "build"
        }
    ]
}
